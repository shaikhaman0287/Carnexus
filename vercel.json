{
  "version": 2,
  "builds": [
    { "src": "server/server.js", "use": "@vercel/node" },
    { "src": "client/src/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/client/src/index.html" },
    { "src": "^/api/(.*)$", "dest": "/server/server.js" },
    { "src": "^/(.*)$", "dest": "/client/src/$1" }
  ]
}
