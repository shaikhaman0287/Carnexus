{
  "version": 2,
  "builds": [
    { "src": "server/server.js", "use": "@vercel/node" },
    { "src": "client/src/**/*", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/server.js" },
    { "source": "/", "destination": "/client/src/index.html" },
    { "source": "/(.*)", "destination": "/client/src/$1" }
  ]
}
