{
  "version": 2,
  "builds": [
    { "src": "Carnexus-main/server/server.js", "use": "@vercel/node" },
    { "src": "Carnexus-main/client/src/**/*", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/Carnexus-main/server/server.js" },
    { "source": "/", "destination": "/Carnexus-main/client/src/pages/index.html" },
    { "source": "/([a-zA-Z0-9-]+\\.html)", "destination": "/Carnexus-main/client/src/pages/$1" },
    { "source": "/(.*)", "destination": "/Carnexus-main/client/src/$1" }
  ]
}
